# ============================================================
# OpportunityScanner - Twitter Automation Environment Config
# Copy this file to .env and fill in your actual values
# ============================================================

# --- Link-AI API Configuration ---
LINKAI_API_KEY=your_linkai_api_key_here
LINKAI_API_BASE=https://api1.link-ai.cc
LINKAI_TEXT_MODEL=claude-opus-4-5-20251101
LINKAI_IMAGE_MODEL=gpt-image-2

# --- Multi-Source Data Feeds ---
# Enable/disable each data source
RSS_FEEDS_ENABLED=true
RESEARCH_FEEDS_ENABLED=true
HN_ALGOLIA_ENABLED=true
TWITTER_ENABLED=true

# --- Twitter Data Source ---
# Search keywords for Twitter (comma separated)
TWITTER_KEYWORDS=AI tools launch,GPT-5,Claude 4,AI startup funding,AI automation business
TWITTER_MAX_RESULTS=20
TWITTER_DAYS_BACK=3
TWITTER_DEFAULT_METHOD=rss  # snscrape | rss | mock
TWITTER_LANGUAGES=en,pt

# --- RSS News Feeds (no API key needed) ---
# Built-in feeds: TechCrunch AI, VentureBeat, The Verge, MIT Tech Review, Wired AI, Ars Technica, MarkTechPost, HN Top
# Custom feeds can be added by name in config

# --- Research Feeds (no API key needed) ---
# arXiv categories: cs.AI, cs.LG, cs.CL, cs.CV, cs.NE
# HuggingFace Daily Papers: automatically included

# --- HN Algolia Search (no API key needed) ---
# Keywords are auto-configured for AI content

# --- SMTP Email Configuration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=OpportunityScanner <your_email@gmail.com>

# Comma-separated recipient list
EMAIL_TO=recipient1@example.com,recipient2@example.com

# --- Optional: Existing APIs (kept from previous version) ---
SERPER_API_KEY=your_serper_api_key_here
DOUBAO_API_KEY=your_doubao_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GITHUB_TOKEN=your_github_token_here

# --- Application Settings ---
NODE_ENV=development
LOG_LEVEL=info
MAX_CONCURRENCY=3
MAX_TWEET_LENGTH=250

# --- Workflow Mode ---
# twitter-auto   : Twitter automation workflow (single source)
# all-sources    : Multi-source aggregator (RSS + arXiv + HN + Twitter) [RECOMMENDED]
# business-radar : Business radar mode (existing)
# classic        : Classic opportunity scanner (existing)
WORKFLOW_MODE=all-sources

# ============================================================
# Setup Instructions:
#
# 1. Link-AI API Key:
#    Get your API key from https://api1.link-ai.cc
#
# 2. Data Sources (ALL FREE, no API key needed):
#    - RSS: Use rss-parser, automatically fetches from built-in feeds
#    - arXiv: Atom Feed API, no key required
#    - HuggingFace: Public API, no key required
#    - HN Algolia: Official HN search API, no key required
#    - Twitter: Nitter RSS (recommended) - free, no key
#
# 3. Gmail SMTP:
#    Enable 2FA → App Passwords → Create new app password
#    Use the generated 16-char password as SMTP_PASS
#
#    For other providers:
#    - QQ Mail: smtp.qq.com, port 587
#    - Outlook: smtp-mail.outlook.com, port 587
#    - Amazon SES: email-smtp.us-east-1.amazonaws.com, port 587
#
# 4. Running:
#    npx tsx src/OpportunityHunter.ts -a  # Recommended (all sources)
#    npx tsx src/OpportunityHunter.ts -t  # Twitter only
#    npx tsx src/OpportunityHunter.ts     # Classic mode
# ============================================================
