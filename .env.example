# Opportunity Hunter - 环境变量配置
# Copy this file to .env and fill in your actual keys

# ====================
# API Keys
# ====================

# Serper API (Google Search via API) - 已在代码中硬编码
# SERPER_API_KEY=e2855f3cec91e07e97afb7513f5f672c48d44e34

# Doubao (豆包) - 火山引擎
DOUBAO_API_KEY=your-doubao-api-key-here
# 豆包 Endpoint ID
DOUBAO_ENDPOINT_ID=ep-20260115140805-6nxf5

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ====================
# GitHub Integration
# ====================

# GitHub Personal Access Token (for creating issues)
GITHUB_TOKEN=your-github-token-here

# GitHub Repository (format: owner/repo)
GITHUB_REPOSITORY=your-username/your-repo
